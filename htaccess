Options -Indexes
ServerSignature Off

# Active la protection en préfixe pour tous les scripts PHP
php_value auto_prepend_file /home/vize/www/wb/protect.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Laisser passer les fichiers statiques (images, CSS, etc.)
    RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|ico|svg|woff2?|ttf|eot|webp|pdf)$ [NC]
    RewriteRule .* - [L]

    # Interdire l'accès direct aux fichiers sensibles
    RewriteRule ^(protect\.php|\.user\.ini)$ - [F]

    # Si le fichier ou dossier n'existe pas, on redirige vers index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

DirectoryIndex index.php